{
  "name": "@restorecommerce/libs",
  "version": "0.0.1",
  "description": "Library monorepo for Restorecommerce",
  "main": "index.js",
  "author": "n-fuse GmbH",
  "scripts": {
    "bootstrap": "npm i --legacy-peer-deps",
    "publish": "lerna publish --conventional-commits",
    "changed": "lerna changed",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "build:clean": "nx run-many -t build:clean",
    "clean": "rimraf -g **/node_modules/ package-lock.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/restorecommerce/libs.git"
  },
  "bugs": {
    "url": "https://github.com/restorecommerce/libs/issues"
  },
  "license": "MIT",
  "homepage": "https://github.com/restorecommerce/libs#readme",
  "devDependencies": {
    "cz-conventional-changelog": "^3.3.0",
    "lerna": "^8.1.8",
    "nx": "20.0.8",
    "rimraf": "^6.1.3",
    "tar": "^7.4.3",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "packages/*"
  ]
}
