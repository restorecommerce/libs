{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "incremental": false,
    "lib": [
      "ES2025",
      "dom"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "strictNullChecks": false,
    "target": "ES2025",
  },
  "ts-node": {
    "experimentalResolver": true,
    "files": true,
    "transpileOnly": true,
    "esm": true,
    "experimentalSpecifierResolution": "node",
  }
}
