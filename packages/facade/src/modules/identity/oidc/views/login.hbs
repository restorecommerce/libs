<div class="flex col justify-center rc-login-form-bg">
  <div class="self-center justify-center rc-login-form">
    <div class="scale110p">
      <h2>Log in to Xingular</h2>
      <div class="row rc-login-form-inner">
        <div class="w-45p gutter-margin-t-b">
          <form novalidate="" vclmaterial="" class="form m-0 ng-untouched ng-pristine ng-invalid">
            <vcl-form-control-group vclmaterial="float" vclcontroltype="input" class="form-control-group material">
              <label vclformcontrollabel="" for="vcl_input_2" class="form-control-label">E-Mail or Username</label>
              <input vclinput="" type="text" name="username" autocomplete="true" class="input ng-untouched ng-pristine ng-invalid" id="vcl_input_2">
            </vcl-form-control-group>
            <vcl-form-control-group vclmaterial="float" vclcontroltype="input" class="form-control-group material">
              <label vclformcontrollabel="" for="vcl_input_3" class="form-control-label">Password</label>
              <input vclinput="" type="password" name="password" autocomplete="true" class="input ng-untouched ng-pristine ng-invalid" id="vcl_input_3">
            </vcl-form-control-group>
            <div class="row justify-between">
              <button type="button" class="button half-transparent">
                Forgot your password?
              </button>
              <button vcl-button="" type="submit" class="button disabled" aria-pressed="false" disabled="true">
                Log in

              </button>
            </div>
          </form>
          <!---->
        </div>
        <div class="w-10p divider divider-vertical row center justify-center rc-login-form-divider-v">
          <div class="divider-rule"></div>
          <div class="icogram divider-element">
            <div class="text">or</div>
          </div>
        </div>
        <div class="divider divider-horizontal row justify-center rc-login-form-divider-h">
          <div class="divider-rule"></div>
          <div class="icogram divider-element">
            <div class="text">or</div>
          </div>
        </div>
        <div class="w-45p col justify-center gutter-margin-t-b">
          <a href="https://xingular.io/en/start-now/" class="col justify-center">
            <button type="button" class="button emphasized">
              Create an Account
            </button>
          </a>
        </div>
      </div>
    </div>
  </div>
  <p class="rc-login-screen-legal">
    © 2017 - 2020 · Xingular UG · All rights reserved.
  </p>
</div>
