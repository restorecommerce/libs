{
  "extends": "../dev/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@modules": ["src/modules/index"],
      "@modules/*": ["src/modules/*"],
      "@gql": ["src/gql/index"],
      "@gql/*": ["src/gql/*"]
    },
    "types": ["node"]
  }
}
