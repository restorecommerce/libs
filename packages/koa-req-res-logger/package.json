{
  "name": "@restorecommerce/koa-req-res-logger",
  "version": "1.2.1",
  "description": "Koa 2 middleware which logs incoming requests and outgoing responses",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "author": "n-fuse GmbH",
  "repository": {
    "type": "git",
    "url": "https://github.com/restorecommerce/koa-req-res-logger.git"
  },
  "license": "MIT",
  "keywords": [
    "restore",
    "commerce",
    "koa",
    "request",
    "logger",
    "middleware"
  ],
  "scripts": {
    "lint": "eslint src",
    "build:tsc": "tsc -p ./tsconfig.lib.json",
    "build:clean": "rimraf ./lib",
    "build": "npm-run-all lint build:clean build:tsc",
    "test": "vitest run",
    "lcov-report": "nyc report --reporter=lcov",
    "coveralls": "nyc --reporter text --reporter lcov npm test"
  },
  "dependencies": {
    "@restorecommerce/logger": "^1.4.1",
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "is-generator": "^1.0.3",
    "isomorphic-fetch": "^3.0.0",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "npm-run-all": "^4.1.5",
    "should": "^13.2.3"
  },
  "engines": {
    "node": ">= 8.0.0"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/lib"
        ]
      }
    }
  },
  "gitHead": "0a6f7c94bfb1811c5dd60ab8c4912a41299b3717"
}
