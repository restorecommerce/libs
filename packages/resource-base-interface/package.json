{
  "name": "@restorecommerce/resource-base-interface",
  "version": "1.10.0",
  "description": "Restorecommerce Resource Base Interface",
  "main": "lib/index.js",
  "typings": "./lib/index.d.ts",
  "author": "n-fuse GmbH",
  "repository": {
    "type": "git",
    "url": "https://github.com/restorecommerce/resource-base-interface.git"
  },
  "license": "MIT",
  "keywords": [
    "restore",
    "commerce",
    "resource",
    "base",
    "interface"
  ],
  "type": "module",
  "dependencies": {
    "@restorecommerce/acs-client": "^3.2.0",
    "@restorecommerce/chassis-srv": "^1.9.0",
    "@restorecommerce/grpc-client": "^2.3.0",
    "@restorecommerce/kafka-client": "^1.4.0",
    "@restorecommerce/rc-grpc-clients": "^5.2.0",
    "@restorecommerce/scs-jobs": "^0.3.0",
    "@restorecommerce/service-config": "^1.2.0",
    "nice-grpc-server-reflection": "^3.0.5",
    "redis": "4.7.0",
    "remeda": "^2.39.0"
  },
  "devDependencies": {
    "@restorecommerce/dev": "^0.3.0",
    "@types/nconf": "^0.10.7",
    "@types/redis": "4.0.2",
    "arangojs": "^10.3.1",
    "cross-env": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "should": "^13.2.3"
  },
  "scripts": {
    "lint": "eslint src --fix",
    "build:es": "esbuild ./src/index.ts --bundle --platform=node --outfile=lib/index.cjs --minify --tree-shaking=true --sourcemap=inline",
    "build:tsc": "tsc -p ./tsconfig.lib.json",
    "build:clean": "rimraf ./lib",
    "build": "npm-run-all lint build:clean build:tsc",
    "test": "vitest run"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/lib"
        ]
      }
    }
  },
  "engines": {
    "node": ">= 20.0.0"
  }
}
