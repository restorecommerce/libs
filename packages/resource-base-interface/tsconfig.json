{
  "extends": "../dev/tsconfig.json",
  "include": [
    "./src/core/*.ts",
    "./src/experimental/*.ts",
    "./src/*.ts",
  ],
  "exclude": [
    "node_modules",
    "lib",
    "doc"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "lib",
    "experimentalDecorators": true,
    "types": ["node"]
  },
}